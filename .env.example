# Copy to server/.env (optional). All values have sensible defaults.

# Port the API/server listens on
PORT=3001

# Optional NCBI API key. Without it, requests are throttled to ~3/sec.
# With a key (free, from https://www.ncbi.nlm.nih.gov/account/), ~10/sec.
NCBI_API_KEY=

# Contact email sent to NCBI with each request (politeness, per their usage policy)
NCBI_EMAIL=changeme@website.com

# Where the SQLite database file lives (relative to project root)
DB_PATH=data/app.db

# Where uploaded PDFs are stored, content-addressed by hash (relative to project root)
BLOBS_DIR=data/blobs

# Cron schedule for the daily background poll (seeds the setting on first run;
# afterwards the value saved in Settings wins)
POLL_CRON=0 6 * * *
