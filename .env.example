# Copy to server/.env (optional). All values have sensible defaults.
#
# Deploy-level config only. The NCBI API key, contact email, and poll schedule
# are managed in the app's Settings UI (gear icon), not here.

# Port the API/server listens on
PORT=3001

# Where the SQLite database file lives (relative to project root)
DB_PATH=data/app.db

# Where uploaded PDFs are stored, content-addressed by hash (relative to project root)
BLOBS_DIR=data/blobs

# Host/interface the server binds to. Default 127.0.0.1 = this machine only.
# Set to 0.0.0.0 (or a specific LAN/Tailscale IP) to let other devices connect.
# The server refuses to start on a non-loopback host unless ADMIN_TOKEN is set.
HOST=127.0.0.1

# Admin token. When set, anyone who can reach the server can VIEW all metadata
# (papers, abstracts, timelines, graphs, PubMed links), but stored PDFs are
# owner-only and changing anything (settings, topics, journals, uploads,
# refresh) requires unlocking the UI with this token (padlock in the header).
# The owner can copy expiring share links (per file, or a whole collection
# as a zip); rotating this token invalidates all outstanding links.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=
