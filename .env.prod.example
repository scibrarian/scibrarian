# Copy to `.env` for `docker compose -f docker-compose.prod.yml ...`.

# Long random string. Guards mutations and stored-PDF downloads.
# Generate one:  openssl rand -hex 32
ADMIN_TOKEN=

# The public hostname for this instance. Create a DNS A record pointing it at
# this server's public IP before starting (see DEPLOY.md).
DOMAIN=scibrarian.example.com

# Email for Let's Encrypt certificate expiry notices.
ACME_EMAIL=you@example.com
